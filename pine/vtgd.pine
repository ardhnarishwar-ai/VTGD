//@version=5
indicator("VTGD Cockpit v0.1", overlay=true, precision=2)

//==================================================
// VTGD v0.1
// Vehicle Theory Greeks Dashboard
// Mobile-First TradingView Cockpit
// Author : Raja × Scarlett
//==================================================


//==================================================
// SECTION 01 : INPUTS
//==================================================

//---------- General ----------
groupGeneral = "General"

expiryDays       = input.int(7, "Expiry Days", minval=0, group=groupGeneral)
strikeStep       = input.int(50, "Strike Interval", options=[50, 100], group=groupGeneral)
strikeCount      = input.int(11, "Total Strikes", minval=11, maxval=11, group=groupGeneral)

//---------- VTGD Engine ----------
groupEngine = "VTGD Engine"

momentumFactor   = input.float(100.0, "Momentum Factor", step=1.0, group=groupEngine)
safetyThreshold  = input.float(0.0, "Safety Threshold", step=0.1, group=groupEngine)

//---------- Cockpit ----------
groupCockpit = "Cockpit"

showCockpit      = input.bool(true, "Show VTGD Cockpit", group=groupCockpit)
collapseCockpit  = input.bool(false, "Start Minimized", group=groupCockpit)

theme = input.string(
    "Sunrise",
    "Theme",
    options=["Sunrise", "Classic"],
    group=groupCockpit)

//---------- Strike Scanner ----------
groupScanner = "Strike Scanner"

showScanner = input.bool(true, "Show Strike Scanner", group=groupScanner)

//---------- Prediction ----------
groupPrediction = "Prediction"

enablePrediction = input.bool(true, "Enable Prediction Engine", group=groupPrediction)
//==================================================

//==================================================
// SECTION 02 : UTILITY FUNCTIONS
//==================================================

//-----------------------------------------------
// Clamp Value
//-----------------------------------------------
clamp(value, minValue, maxValue) =>
    math.max(minValue, math.min(maxValue, value))

//-----------------------------------------------
// Normalize Value (0 - 100)
//-----------------------------------------------
normalize(value, maxValue) =>
    maxValue == 0 ? 0 : clamp((value / maxValue) * 100, 0, 100)

//-----------------------------------------------
// Progress Bar (████░░░░)
//-----------------------------------------------
progressBar(percent, blocks) =>
    filled = math.round(clamp(percent, 0, 100) / 100 * blocks)
    bar = ""

    for i = 0 to blocks - 1
        bar += i < filled ? "█" : "░"

    bar

//-----------------------------------------------
// Safety Label
//-----------------------------------------------
safetyLabel(score) =>
    score >= 80 ? "STRONG" :
     score >= 60 ? "GOOD" :
     score >= 40 ? "CAUTION" :
     "DANGER"

//-----------------------------------------------
// Mode Label
//-----------------------------------------------
modeLabel(score) =>
    score >= 80 ? "ZERO → HERO" :
     score >= 60 ? "ROLLING" :
     score >= 40 ? "WAIT" :
     "EXIT FAST"

//-----------------------------------------------
// Round to 2 Decimal
//-----------------------------------------------
round2(value) =>
    math.round(value * 100) / 100

//-----------------------------------------------
// YES / NO Flag
//-----------------------------------------------
yesNo(condition) =>
    condition ? "YES" : "NO"
//==================================================

//==================================================
// SECTION 03 : STRIKE ENGINE (ATM ±5)
//--------------------------------------------------
// Spot Price
//--------------------------------------------------

spot = close

//--------------------------------------------------
// ATM Strike
//--------------------------------------------------

atmStrike =
    math.round(spot / strikeStep) * strikeStep

//--------------------------------------------------
// 11 Strike Array
//--------------------------------------------------

var strikeList = array.new_float()

if barstate.isfirst
    array.clear(strikeList)

for i = 5 to 1 by -1
    array.push(strikeList, atmStrike + i * strikeStep)

array.push(strikeList, atmStrike)

for i = 1 to 5
    array.push(strikeList, atmStrike - i * strikeStep)


//--------------------------------------------------
// Helper Function
//--------------------------------------------------

getStrike(index) =>
    array.get(strikeList, index)
//==================================================

//==================================================
// SECTION 04 : GREEKS ENGINE
//--------------------------------------------------
// Time to Expiry (Years)
//--------------------------------------------------

T = expiryDays / 365.0

//--------------------------------------------------
// Risk Free Rate
//--------------------------------------------------

riskFree = 0.05

//--------------------------------------------------
// Implied Volatility
//--------------------------------------------------

iv = ta.stdev(math.log(close / close[1]), 30) * math.sqrt(252)

//--------------------------------------------------
// Normal Distribution
//--------------------------------------------------

normPDF(x) =>
    math.exp(-0.5 * x * x) / math.sqrt(2 * math.pi)

normCDF(x) =>
    0.5 * (1 + math.erf(x / math.sqrt(2)))

//--------------------------------------------------
// Black-Scholes d1 / d2
//--------------------------------------------------

calcD1(S, K, sigma) =>
    (math.log(S / K) + (riskFree + sigma * sigma / 2) * T) /
    (sigma * math.sqrt(T))

calcD2(d1, sigma) =>
    d1 - sigma * math.sqrt(T)

//--------------------------------------------------
// Greeks
//--------------------------------------------------

calcDelta(d1) =>
    normCDF(d1)

calcGamma(S, sigma, d1) =>
    normPDF(d1) /
    (S * sigma * math.sqrt(T))

calcVega(S, d1) =>
    S * normPDF(d1) * math.sqrt(T)

calcTheta(S, K, sigma, d1, d2) =>
    -(S * normPDF(d1) * sigma) /
    (2 * math.sqrt(T))
//==================================================

//==================================================
// SECTION 05 : VTGD SAFETY ENGINE
//--------------------------------------------------
// Intrinsic Value
//--------------------------------------------------

calcIntrinsic(S, K) =>
    math.max(S - K, 0)

//--------------------------------------------------
// Decay
//--------------------------------------------------

calcDecay(theta) =>
    math.abs(theta)

//--------------------------------------------------
// VTGD Safety Score
//--------------------------------------------------

calcSafety(S, K, delta, gamma, vega, theta) =>

    intrinsic = calcIntrinsic(S, K)

    decay = calcDecay(theta)

    safety =
          (intrinsic * math.abs(delta))
        + (gamma * vega * momentumFactor)
        - (decay * vega)

    safety

//--------------------------------------------------
// Normalize Safety (0 - 100)
//--------------------------------------------------

calcSafetyPercent(score) =>

    normalize(score, safetyThreshold)

//--------------------------------------------------
// Safety Label
//--------------------------------------------------

calcSafetyStatus(score) =>

    safetyLabel(calcSafetyPercent(score))
//==================================================

//==================================================
// SECTION 06 : NW / DIFFUSION ENGINE
//--------------------------------------------------
// Price Momentum
//--------------------------------------------------

priceMomentum =
    close - close[1]

//--------------------------------------------------
// Natural Weight (NW)
//--------------------------------------------------

nw =
    gamma * vega

//--------------------------------------------------
// Diffusion Direction
//--------------------------------------------------

diffusionBullish =
    nw >= 0

//--------------------------------------------------
// Trend Direction
//--------------------------------------------------

trendBullish =
    priceMomentum >= 0

//--------------------------------------------------
// Trend vs Diffusion
//--------------------------------------------------

trendMatchesDiffusion =
    trendBullish == diffusionBullish

//--------------------------------------------------
// Prediction Mode
//--------------------------------------------------

predictionMode =
    not trendMatchesDiffusion

//--------------------------------------------------
// Dashboard Labels
//--------------------------------------------------

diffusionLabel =
    diffusionBullish ? "BULLISH" : "BEARISH"

trendLabel =
    trendBullish ? "UP" : "DOWN"

predictionLabel =
    predictionMode ? "PREDICTION" : "DATA"

modeLabel =
    predictionMode ? "OPPOSITE" : "FOLLOW"
//==================================================


//==================================================
// SECTION 07 : PCR ENGINE (11 Strikes)
//==================================================

//--------------------------------------------------
// PCR Inputs
//--------------------------------------------------

enablePCR = input.bool(true, "Enable PCR Engine", group="PCR")
manualPCR = input.float(1.00, "Manual PCR", step=0.01, group="PCR")

//--------------------------------------------------
// PCR Value
//--------------------------------------------------

pcr = manualPCR

//--------------------------------------------------
// PCR Status
//--------------------------------------------------

pcrBullish = pcr > 1.20
pcrBearish = pcr < 0.80
pcrNeutral = not pcrBullish and not pcrBearish

//--------------------------------------------------
// PCR Label
//--------------------------------------------------

pcrLabel =
     pcrBullish ? "BULLISH" :
     pcrBearish ? "BEARISH" :
     "NEUTRAL"

//--------------------------------------------------
// PCR Color
//--------------------------------------------------

pcrColor =
     pcrBullish ? color.lime :
     pcrBearish ? color.red :
     color.orange
//==================================================

//==================================================
// SECTION 08 : FVP ENGINE (VWAP / Fair Value Price)
//==================================================

//--------------------------------------------------
// Fair Value Price (VWAP)
//--------------------------------------------------

fvp = ta.vwap(close)

//--------------------------------------------------
// Distance From FVP
//--------------------------------------------------

fvpDistance =
    spot - fvp

//--------------------------------------------------
// FVP Direction
//--------------------------------------------------

aboveFVP =
    spot >= fvp

//--------------------------------------------------
// Fair Value Status
//--------------------------------------------------

fvpStatus =
    aboveFVP ? "ABOVE FVP" : "BELOW FVP"

//--------------------------------------------------
// Fair Value Color
//--------------------------------------------------

fvpColor =
    aboveFVP ? color.lime : color.red
//==================================================


//==================================================
// SECTION 09 : PREDICTION ENGINE
// Trend vs Diffusion
// Opposite Diffusion Alert
// Zero → Hero
//--------------------------------------------------
// Prediction Mode
//--------------------------------------------------

predictionMode =
    trendBullish != diffusionBullish

//--------------------------------------------------
// Prediction Signal
//--------------------------------------------------

predictionSignal =
    predictionMode ? "OPPOSITE" : "FOLLOW"

//--------------------------------------------------
// VTGD Mode
//--------------------------------------------------

vtgdMode =
    predictionMode ?
        "ZERO → HERO" :
        safetyLabel(calcSafetyPercent(calcSafety(S, atmStrike, calcDelta(calcD1(S, atmStrike, iv)), calcGamma(S, iv, calcD1(S, atmStrike, iv)), calcVega(S, calcD1(S, atmStrike, iv)), calcTheta(S, atmStrike, iv, calcD1(S, atmStrike, iv), calcD2(calcD1(S, atmStrike, iv), iv))))) 

//--------------------------------------------------
// Prediction Color
//--------------------------------------------------

predictionColor =
    predictionMode ? color.orange : color.lime
//==================================================


//==================================================
// SECTION 10 : VTGD COCKPIT UI
//--------------------------------------------------
// Dashboard Table
//--------------------------------------------------

var table cockpit = table.new(position.top_right, 2, 12, border_width=1)

//--------------------------------------------------
// Update Dashboard
//--------------------------------------------------

if showCockpit and barstate.islast

    table.cell(cockpit, 0, 0, "VTGD", bgcolor=color.blue, text_color=color.white)
    table.cell(cockpit, 1, 0, "v0.1", bgcolor=color.blue, text_color=color.white)

    table.cell(cockpit, 0, 1, "Spot")
    table.cell(cockpit, 1, 1, str.tostring(round2(spot)))

    table.cell(cockpit, 0, 2, "ATM")
    table.cell(cockpit, 1, 2, str.tostring(atmStrike))

    table.cell(cockpit, 0, 3, "Safety")
    table.cell(cockpit, 1, 3, calcSafetyStatus(calcSafety(spot, atmStrike, calcDelta(calcD1(spot, atmStrike, iv)), calcGamma(spot, iv, calcD1(spot, atmStrike, iv)), calcVega(spot, calcD1(spot, atmStrike, iv)), calcTheta(spot, atmStrike, iv, calcD1(spot, atmStrike, iv), calcD2(calcD1(spot, atmStrike, iv), iv))))

    table.cell(cockpit, 0, 4, "Mode")
    table.cell(cockpit, 1, 4, vtgdMode)

    table.cell(cockpit, 0, 5, "PCR")
    table.cell(cockpit, 1, 5, pcrLabel)

    table.cell(cockpit, 0, 6, "Diffusion")
    table.cell(cockpit, 1, 6, diffusionLabel)

    table.cell(cockpit, 0, 7, "Trend")
    table.cell(cockpit, 1, 7, trendLabel)

    table.cell(cockpit, 0, 8, "Prediction")
    table.cell(cockpit, 1, 8, predictionSignal)

    table.cell(cockpit, 0, 9, "FVP")
    table.cell(cockpit, 1, 9, fvpStatus)

    table.cell(cockpit, 0, 10, "Scanner")
    table.cell(cockpit, 1, 10, yesNo(showScanner))

    table.cell(cockpit, 0, 11, "Engine")
    table.cell(cockpit, 1, 11, yesNo(enablePrediction))
//==================================================


//==================================================
// SECTION 11 : STRIKE SCANNER
//==================================================
